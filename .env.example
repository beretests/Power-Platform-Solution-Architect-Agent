# Azure OpenAI
AZURE_OPENAI_BASE_URL=https://<your-openai-resource>.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT=<your-chat-deployment-name>

# Foundry IQ / Azure AI Search knowledge base
# Set FOUNDRY_IQ_ENABLED=false to use the local knowledge/ folder as grounding fallback.
FOUNDRY_IQ_ENABLED=true
FOUNDRY_IQ_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
FOUNDRY_IQ_KNOWLEDGE_BASE=power-platform-architecture-kb
FOUNDRY_IQ_API_VERSION=2026-05-01-preview
# Supported values: api-key, managed-identity
FOUNDRY_IQ_AUTH_MODE=api-key

# Required only when FOUNDRY_IQ_AUTH_MODE=api-key
AZURE_SEARCH_API_KEY=<your-search-key>
